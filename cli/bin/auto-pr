#!/bin/bash
# auto-pr - 全自动 PR 提交工具
# 用法: auto-pr <command> [options]

set -euo pipefail

# 获取脚本所在目录
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SRC_DIR="$SCRIPT_DIR/../src"
TEMPLATE_DIR="$SCRIPT_DIR/../templates"

# 加载模块
# shellcheck source=src/checks.sh
source "$SRC_DIR/checks.sh"
# shellcheck source=src/submit.sh
source "$SRC_DIR/submit.sh"
# shellcheck source=src/watch.sh
source "$SRC_DIR/watch.sh"
# shellcheck source=src/fix.sh
source "$SRC_DIR/fix.sh"
# ============================================================
# 配置文件加载
# ============================================================

# 默认配置
DEFAULT_CONFIG=(
    "project.type=auto"
    "project.style.use_var=false"
    "project.style.use_arrow_functions=true"
    "project.style.server_module=commonjs"
    "project.style.client_module=esm"
    "pr.base_branch=main"
    "pr.commit_style=angular"
    "pr.add_co_authored_by=false"
    "ci.watch_interval=30"
    "ci.max_fix_attempts=3"
    "ci.auto_fix=true"
    "ci.auto_merge=false"
    "review.copilot=true"
    "review.coderabbit=true"
    "review.timeout=300"
    "checks.syntax=true"
    "checks.lint=true"
    "checks.test=true"
    "checks.typecheck=false"
    "checks.build=false"
    "logging.level=info"
    "logging.save_to_file=false"
)

# 加载配置文件
load_config() {
    local config_file="${1:-.auto-pr.yml}"
    
    # 如果配置文件不存在，使用默认配置
    if [ ! -f "$config_file" ]; then
        log_info "使用默认配置"
        return
    fi
    
    log_info "加载配置文件: $config_file"
    
    # 读取配置文件
    while IFS= read -r line; do
        # 跳过注释和空行
        [[ "$line" =~ ^[[:space:]]*# ]] && continue
        [[ -z "$line" ]] && continue
        
        # 解析配置
        if [[ "$line" =~ ^[[:space:]]*([a-zA-Z_]+):[[:space:]]*(.*)$ ]]; then
            local key="${BASH_REMATCH[1]}"
            local value="${BASH_REMATCH[2]}"
            
            # 移除引号
            value="${value%\"}"
            value="${value#\"}"
            value="${value%\'}"
            value="${value#\'}"
            
            # 设置配置
            export "AUTO_PR_${key^^}=$value"
        fi
    done < "$config_file"
}

# 获取配置值
get_config() {
    local key="$1"
    local default="$2"
    
    # 尝试从环境变量获取
    local env_key="AUTO_PR_${key^^}"
    local value="${!env_key}"
    
    # 如果环境变量不存在，使用默认值
    if [ -z "$value" ]; then
        value="$default"
    fi
    
    echo "$value"
}

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# 日志函数
log_info() { echo -e "${BLUE}ℹ️  $1${NC}"; }
log_success() { echo -e "${GREEN}✅ $1${NC}"; }
log_warn() { echo -e "${YELLOW}⚠️  $1${NC}"; }
log_error() { echo -e "${RED}❌ $1${NC}"; }

# 检测项目类型
detect_project_type() {
    if [ -f "Cargo.toml" ]; then
        echo "rust"
    elif [ -f "package.json" ]; then
        echo "node"
    elif [ -f "requirements.txt" ] || [ -f "pyproject.toml" ]; then
        echo "python"
    elif [ -f "go.mod" ]; then
        echo "go"
    else
        echo "unknown"
    fi
}

# 获取 owner/repo
get_owner_repo() {
    local remote_url
    remote_url=$(git remote get-url origin 2>/dev/null || echo "")
    if [ -z "$remote_url" ]; then
        log_error "未找到 git remote"
        exit 1
    fi
    echo "$remote_url" | sed -E 's|.*github\.com[:/]||; s|\.git$||'
}

# ============================================================
# init - 初始化项目配置
# ============================================================
cmd_init() {
    log_info "初始化项目配置..."
    
    local project_type
    project_type=$(detect_project_type)
    log_info "检测到项目类型: $project_type"
    
    # 创建 .github 目录
    mkdir -p .github/workflows
    mkdir -p .github/instructions
    
    # 1. PR 模板
    if [ ! -f ".github/pull_request_template.md" ]; then
        cp "$TEMPLATE_DIR/pr-template.md" .github/pull_request_template.md
        log_success "创建 PR 模板"
    else
        log_warn "PR 模板已存在，跳过"
    fi
    
    # 2. Copilot 自定义指令
    if [ ! -f ".github/copilot-instructions.md" ]; then
        cp "$TEMPLATE_DIR/copilot-instructions.md" .github/copilot-instructions.md
        log_success "创建 Copilot 自定义指令"
    else
        log_warn "Copilot 指令已存在，跳过"
    fi
    
    # 3. CodeRabbit 配置
    if [ ! -f ".coderabbit.yaml" ]; then
        cp "$TEMPLATE_DIR/coderabbit.yaml" .coderabbit.yaml
        log_success "创建 CodeRabbit 配置"
    else
        log_warn "CodeRabbit 配置已存在，跳过"
    fi
    
    # 4. 根据项目类型创建 CI
    case $project_type in
        rust)
            create_rust_ci
            create_dependabot "cargo"
            ;;
        node)
            create_node_ci
            create_dependabot "npm"
            ;;
        python)
            create_python_ci
            create_dependabot "pip"
            ;;
        go)
            create_go_ci
            create_dependabot "gomod"
            ;;
        *)
            log_warn "未知项目类型，跳过 CI 配置"
            ;;
    esac
    
    log_success "初始化完成！"
    echo ""
    echo "已创建的文件："
    ls -la .github/ .coderabbit.yaml 2>/dev/null || true
}

# 创建 Rust CI
create_rust_ci() {
    if [ ! -f ".github/workflows/ci.yml" ]; then
        cat > .github/workflows/ci.yml << 'CIEOF'
name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

env:
  CARGO_TERM_COLOR: always

jobs:
  check:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      
      - name: Setup Rust
        uses: dtolnay/rust-toolchain@stable
        with:
          components: rustfmt, clippy
      
      - name: Rust cache
        uses: swatinem/rust-cache@v2
      
      - name: Check formatting
        run: cargo fmt --check
      
      - name: Clippy
        run: cargo clippy -- -D warnings
      
      - name: Tests
        run: cargo test
CIEOF
        log_success "创建 Rust CI workflow"
    fi
}

# 创建 Node.js CI
create_node_ci() {
    if [ ! -f ".github/workflows/ci.yml" ]; then
        cat > .github/workflows/ci.yml << 'CIEOF'
name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  check:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      
      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: 20
      
      - name: Install dependencies
        run: npm ci
      
      - name: Lint
        run: npm run lint
      
      - name: Type check
        run: npm run typecheck || true
      
      - name: Test
        run: npm test
      
      - name: Build
        run: npm run build || true
CIEOF
        log_success "创建 Node.js CI workflow"
    fi
}

# 创建 Python CI
create_python_ci() {
    if [ ! -f ".github/workflows/ci.yml" ]; then
        cat > .github/workflows/ci.yml << 'CIEOF'
name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  check:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      
      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'
      
      - name: Install dependencies
        run: |
          pip install ruff pytest
          pip install -r requirements.txt || true
      
      - name: Lint
        run: ruff check .
      
      - name: Test
        run: pytest || true
CIEOF
        log_success "创建 Python CI workflow"
    fi
}

# 创建 Go CI
create_go_ci() {
    if [ ! -f ".github/workflows/ci.yml" ]; then
        cat > .github/workflows/ci.yml << 'CIEOF'
name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  check:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      
      - name: Setup Go
        uses: actions/setup-go@v5
        with:
          go-version: '1.21'
      
      - name: Lint
        uses: golangci/golangci-lint-action@v3
      
      - name: Test
        run: go test ./...
      
      - name: Build
        run: go build ./...
CIEOF
        log_success "创建 Go CI workflow"
    fi
}

# 创建 Dependabot 配置
create_dependabot() {
    local ecosystem=$1
    if [ ! -f ".github/dependabot.yml" ]; then
        cat > .github/dependabot.yml << DEPEOF
version: 2
updates:
  - package-ecosystem: "$ecosystem"
    directory: "/"
    schedule:
      interval: "weekly"
    open-pull-requests-limit: 5
DEPEOF
        log_success "创建 Dependabot 配置"
    fi
}

# ============================================================
# describe - 自动生成 PR 描述
# ============================================================
cmd_describe() {
    log_info "生成 PR 描述..."
    
    local changes
    changes=$(git diff main...HEAD --stat 2>/dev/null || echo "No changes")
    
    local commit_log
    commit_log=$(git log main..HEAD --oneline 2>/dev/null || echo "No commits")
    
    cat << DESCEOF
## Summary
$(git log -1 --format=%s)

## Changes
\`\`\`
$changes
\`\`\`

## Commits
\`\`\`
$commit_log
\`\`\`

## Test Plan
- [ ] CI passes
- [ ] Code review completed

## Related Issues
N/A
DESCEOF
}

# ============================================================
# main - 主入口
# ============================================================
# ============================================================
# check - 环境检查和依赖验证
# ============================================================
cmd_check() {
    log_info "检查环境和依赖..."
    
    local errors=0
    
    # 1. 检查 Git
    if ! command -v git &> /dev/null; then
        log_error "Git 未安装"
        ((errors++))
    else
        log_success "Git 已安装: $(git --version)"
    fi
    
    # 2. 检查 GitHub CLI
    if ! command -v gh &> /dev/null; then
        log_error "GitHub CLI 未安装"
        ((errors++))
    else
        log_success "GitHub CLI 已安装: $(gh --version | head -1)"
        
        # 检查登录状态
        if ! gh auth status &> /dev/null; then
            log_error "GitHub CLI 未登录"
            ((errors++))
        else
            log_success "GitHub CLI 已登录"
        fi
    fi
    
    # 3. 检查 Git 配置
    if [ -z "$(git config user.name)" ]; then
        log_warn "Git 用户名未配置"
    else
        log_success "Git 用户名: $(git config user.name)"
    fi
    
    if [ -z "$(git config user.email)" ]; then
        log_warn "Git 邮箱未配置"
    else
        log_success "Git 邮箱: $(git config user.email)"
    fi
    
    # 4. 检查项目类型和依赖
    local project_type
    project_type=$(detect_project_type)
    
    case $project_type in
        rust)
            if ! command -v cargo &> /dev/null; then
                log_error "Rust/Cargo 未安装"
                ((errors++))
            else
                log_success "Rust/Cargo 已安装"
            fi
            ;;
        node)
            if ! command -v node &> /dev/null; then
                log_error "Node.js 未安装"
                ((errors++))
            else
                log_success "Node.js 已安装: $(node --version)"
            fi
            
            if ! command -v npm &> /dev/null; then
                log_error "npm 未安装"
                ((errors++))
            else
                log_success "npm 已安装: $(npm --version)"
            fi
            
            # 检查依赖是否安装
            if [ -f "package.json" ] && [ ! -d "node_modules" ]; then
                log_warn "node_modules 不存在"
                if [ -f "package-lock.json" ]; then
                    log_info "运行 npm ci..."
                    npm ci
                else
                    log_info "运行 npm install..."
                    npm install
                fi
            fi
            ;;
        python)
            if ! command -v python3 &> /dev/null; then
                log_error "Python3 未安装"
                ((errors++))
            else
                log_success "Python3 已安装: $(python3 --version)"
            fi
            ;;
        go)
            if ! command -v go &> /dev/null; then
                log_error "Go 未安装"
                ((errors++))
            else
                log_success "Go 已安装: $(go version)"
            fi
            ;;
    esac
    
    # 5. 检查 CI 配置
    if [ -d ".github/workflows" ]; then
        log_success "CI 配置存在"
        ls -la .github/workflows/
    else
        log_warn "没有 CI 配置"
    fi
    
    # 总结
    if [ $errors -eq 0 ]; then
        log_success "环境检查通过！"
    else
        log_error "发现 $errors 个问题，请修复后重试"
        exit 1
    fi
}
main() {
    local command=${1:-help}
    # 加载配置文件
    load_config
    
    case $command in
        init)
            cmd_init
            ;;
        check)
            cmd_check
            ;;
        submit)
            cmd_submit
            ;;
        watch)
            cmd_watch
            ;;
        review)
            cmd_review
            ;;
        merge)
            cmd_merge
            ;;
        describe)
            cmd_describe
            ;;
        help|--help|-h)
            echo "用法: auto-pr <command> [options]"
            echo "  check      检查环境和依赖"
            echo ""
            echo "命令:"
            echo "  init       初始化项目配置"
            echo "  submit     提交 PR（本地检查 → 创建 PR → 触发审查）"
            echo "  watch      监控 CI 并自动修复"
            echo "  review     手动触发 AI 审查"
            echo "  merge      启用 auto-merge"
            echo "  describe   自动生成 PR 描述"
            echo ""
            echo "示例:"
            echo "  auto-pr init      # 初始化项目"
            echo "  auto-pr submit    # 提交 PR"
            echo "  auto-pr watch     # 监控 CI"
            ;;
        *)
            log_error "未知命令: $command"
            echo "运行 'auto-pr --help' 查看帮助"
            exit 1
            ;;
    esac
}

main "$@"
